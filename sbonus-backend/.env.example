# ══════════════════════════════════════════════════════════
# S Bonus+ — Backend Environment Variables
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env
# ══════════════════════════════════════════════════════════

# ─── Режим приложения ────────────────────────────────────
APP_ENV=development          # development | production
DEBUG=true                   # false в production

# ─── Магазин ─────────────────────────────────────────────
SHOP_NAME=Смарт Центр
SHOP_BONUS_NAME=S Bonus
SHOP_ADDRESS=Ошская обл., Аравандский р-н, ул. Ош-3000, 86
SHOP_PHONE=+996557100505
SHOP_COUNTRY=Кыргызстан
SHOP_CURRENCY=KGS
SHOP_TIMEZONE=Asia/Bishkek

# ─── Бонусная логика ─────────────────────────────────────
MIN_PURCHASE_FOR_BONUS=500   # Минимальная сумма покупки для начисления бонуса (KGS)
MAX_SPEND_PERCENT=30         # Максимальный % от покупки для списания бонуса
BIRTHDAY_BONUS=200           # Бонус ко дню рождения (KGS)
REFERRAL_BONUS_INVITER=100   # Бонус пригласившему (KGS)
REFERRAL_BONUS_INVITEE=50    # Бонус новому клиенту по реферальному коду (KGS)

# ─── База данных (PostgreSQL) ─────────────────────────────
POSTGRES_USER=sbonus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sbonus_db
DATABASE_URL=postgresql+asyncpg://sbonus:CHANGE_ME_STRONG_PASSWORD@db:5432/sbonus_db

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT (RS256) ─────────────────────────────────────────
# Ключи генерируются автоматически при первом запуске (entrypoint.sh)
# Для ручной генерации:
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Rate Limiting ───────────────────────────────────────
LOGIN_RATE_LIMIT=5/15min
API_RATE_LIMIT=100/min

# ─── 1С Интеграция ───────────────────────────────────────
ENABLE_1C_WEBHOOK=false
WEBHOOK_1C_SECRET=CHANGE_ME_HMAC_SECRET_MIN_32_CHARS
WEBHOOK_1C_ALLOWED_IPS=127.0.0.1,10.0.0.0/8
# Для отключения проверки IP — оставьте пустым: WEBHOOK_1C_ALLOWED_IPS=

# ─── Green API (WhatsApp уведомления) ────────────────────
ENABLE_WHATSAPP_NOTIFICATIONS=false
GREENAPI_INSTANCE_ID=           # Получить на https://green-api.com
GREENAPI_API_TOKEN=             # Токен инстанса Green API

# ─── CORS ────────────────────────────────────────────────
# Для production укажите реальные домены admin панели
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ══════════════════════════════════════════════════════════
# PRODUCTION CHECKLIST:
# [ ] APP_ENV=production
# [ ] DEBUG=false
# [ ] Сменить POSTGRES_PASSWORD на сложный пароль
# [ ] Сменить WEBHOOK_1C_SECRET
# [ ] Указать CORS_ORIGINS реальный домен
# [ ] Настроить GREENAPI если нужны WhatsApp уведомления
# [ ] Настроить ENABLE_1C_WEBHOOK=true если используете 1С
# ══════════════════════════════════════════════════════════
