////////////////////////////////////////////////////////////////////////////////
// SBonus+ Интеграция — Общий модуль для 1С:УТ 11.5
//
// Функции:
//   1. СинхронизацияТоваровВSBonus()  — ежедневная синхронизация каталога
//   2. ОбновлениеОстатковВSBonus()    — обновление остатков каждый час
//   3. ПриПроведенииЧекаSBonus()      — отправка данных чека при продаже
//   4. ТестСоединения()                — проверка связи с API
//
// Настройки: Константы SB_APIUrl, SB_WebhookSecret, SB_IntegrationEnabled
////////////////////////////////////////////////////////////////////////////////

#Область СлужебныеФункции

// Получить URL API
Функция ПолучитьURLAPI() Экспорт
    Возврат Константы.SB_APIUrl.Получить();
КонецФункции

// Получить секретный ключ HMAC
Функция ПолучитьСекрет() Экспорт
    Возврат Константы.SB_WebhookSecret.Получить();
КонецФункции

// Проверить включена ли интеграция
Функция ИнтеграцияВключена() Экспорт
    Возврат Константы.SB_IntegrationEnabled.Получить();
КонецФункции

// Вычислить HMAC-SHA256 подпись
//
// Параметры:
//   Данные  - Строка - JSON тело запроса
//   Секрет  - Строка - Секретный ключ
//
// Возвращаемое значение:
//   Строка - hex-кодированная подпись
//
Функция ВычислитьHMAC(Данные, Секрет) Экспорт

    ДвоичныеДанныеТела = ПолучитьДвоичныеДанныеИзСтроки(Данные, КодировкаТекста.UTF8);
    ДвоичныеДанныеКлюча = ПолучитьДвоичныеДанныеИзСтроки(Секрет, КодировкаТекста.UTF8);

    Подпись = НовыйОбъект("ХешированиеДанных", ХешФункция.HMAC_SHA256, ДвоичныеДанныеКлюча);
    Подпись.Добавить(ДвоичныеДанныеТела);

    ДвоичныйРезультат = Подпись.ХешСумма;

    // Преобразовать в hex строку
    Результат = "";
    БуферДвоичных = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(ДвоичныйРезультат);
    Для Индекс = 0 По БуферДвоичных.Размер - 1 Цикл
        Байт = БуферДвоичных.ПрочитатьЦелое8(Индекс);
        Если Байт < 0 Тогда
            Байт = Байт + 256;
        КонецЕсли;
        Результат = Результат + Прав("0" + Формат(Байт, "ЧГ=0; ЧС=16"), 2);
    КонецЦикла;

    Возврат НРег(Результат);

КонецФункции

// Отправить HTTP POST запрос к SBonus+ API
//
// Параметры:
//   Endpoint - Строка - путь API (например "/api/v1/webhook/1c/purchase")
//   JSONТело - Строка - JSON строка для отправки
//
// Возвращаемое значение:
//   Структура - Результат: Булево, КодОтвета: Число, Тело: Строка
//
Функция ОтправитьЗапрос(Endpoint, JSONТело) Экспорт

    Результат = Новый Структура("Успех, КодОтвета, Тело", Ложь, 0, "");

    Попытка
        APIUrl = ПолучитьURLAPI();
        Секрет = ПолучитьСекрет();

        Если ПустаяСтрока(APIUrl) ИЛИ ПустаяСтрока(Секрет) Тогда
            Результат.Тело = "Не настроены константы SB_APIUrl или SB_WebhookSecret";
            Возврат Результат;
        КонецЕсли;

        // Разобрать URL
        СтруктураURL = РазобратьURL(APIUrl);

        // Вычислить подпись
        Подпись = ВычислитьHMAC(JSONТело, Секрет);

        // Создать HTTP соединение
        Порт = ?(СтруктураURL.Схема = "https", 443, 80);
        Соединение = Новый HTTPСоединение(
            СтруктураURL.Хост,
            Порт,
            , , , ,
            Новый ЗащищенноеСоединениеOpenSSL()
        );

        // Создать запрос
        Запрос = Новый HTTPЗапрос(Endpoint);
        Запрос.Заголовки.Вставить("Content-Type", "application/json");
        Запрос.Заголовки.Вставить("X-Signature", Подпись);
        Запрос.УстановитьТелоИзСтроки(JSONТело, КодировкаТекста.UTF8);

        // Отправить
        Ответ = Соединение.ВызватьHTTPМетод("POST", Запрос);

        Результат.КодОтвета = Ответ.КодСостояния;
        Результат.Тело = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
        Результат.Успех = (Ответ.КодСостояния >= 200 И Ответ.КодСостояния < 300);

    Исключение
        Результат.Тело = ОписаниеОшибки();
        ЗаписьЖурналаРегистрации("SBonus.Ошибка", УровеньЖурналаРегистрации.Ошибка, , ,
            "Ошибка отправки в SBonus+: " + ОписаниеОшибки());
    КонецПопытки;

    Возврат Результат;

КонецФункции

// Разобрать URL на составные части
Функция РазобратьURL(URL)
    Результат = Новый Структура("Схема, Хост, Путь");

    Если СтрНачинаетсяС(URL, "https://") Тогда
        Результат.Схема = "https";
        Остаток = Сред(URL, 9);
    ИначеЕсли СтрНачинаетсяС(URL, "http://") Тогда
        Результат.Схема = "http";
        Остаток = Сред(URL, 8);
    Иначе
        Результат.Схема = "https";
        Остаток = URL;
    КонецЕсли;

    ПозицияСлеша = СтрНайти(Остаток, "/");
    Если ПозицияСлеша > 0 Тогда
        Результат.Хост = Лев(Остаток, ПозицияСлеша - 1);
        Результат.Путь = Сред(Остаток, ПозицияСлеша);
    Иначе
        Результат.Хост = Остаток;
        Результат.Путь = "/";
    КонецЕсли;

    Возврат Результат;
КонецФункции

#КонецОбласти

#Область СинхронизацияТоваров

// Ежедневная синхронизация товаров из 1С в SBonus+
// Вызывается регламентным заданием каждый день в 06:00
//
Процедура СинхронизацияТоваровВSBonus() Экспорт

    Если НЕ ИнтеграцияВключена() Тогда
        Возврат;
    КонецЕсли;

    ЗаписьЖурналаРегистрации("SBonus.Синхронизация", УровеньЖурналаРегистрации.Информация, , ,
        "Начало синхронизации товаров в SBonus+");

    // Запрос всех активных товаров из справочника Номенклатура
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    Номенклатура.Код КАК Код,
    |    Номенклатура.Наименование КАК Наименование,
    |    Номенклатура.Артикул КАК Артикул,
    |    ЕСТЬNULL(Номенклатура.НоменклатурнаяГруппа.Наименование, """") КАК Категория,
    |    Номенклатура.ЕдиницаИзмерения.Наименование КАК ЕдиницаИзмерения,
    |    ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) КАК Цена,
    |    ЕСТЬNULL(СебестоимостьНоменклатуры.Цена, 0) КАК Себестоимость,
    |    ЕСТЬNULL(ОстаткиТоваров.КоличествоОстаток, 0) КАК Остаток,
    |    ЕСТЬNULL(Штрихкоды.Штрихкод, """") КАК Штрихкод,
    |    ЕСТЬNULL(Номенклатура.Поставщик.Наименование, """") КАК Поставщик
    |ИЗ
    |    Справочник.Номенклатура КАК Номенклатура
    |
    |    ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
    |        ,
    |        ВидЦены = &ВидЦены
    |    ) КАК ЦеныНоменклатуры
    |    ПО Номенклатура.Ссылка = ЦеныНоменклатуры.Номенклатура
    |
    |    ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
    |        ,
    |        ВидЦены = &ВидСебестоимости
    |    ) КАК СебестоимостьНоменклатуры
    |    ПО Номенклатура.Ссылка = СебестоимостьНоменклатуры.Номенклатура
    |
    |    ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки КАК ОстаткиТоваров
    |    ПО Номенклатура.Ссылка = ОстаткиТоваров.Номенклатура
    |
    |    ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
    |    ПО Номенклатура.Ссылка = Штрихкоды.Номенклатура
    |
    |ГДЕ
    |    Номенклатура.ЭтоГруппа = ЛОЖЬ
    |    И НЕ Номенклатура.ПометкаУдаления";

    // ── Виды цен — настройте под свою конфигурацию ──
    // В УТ 11.5 это обычно: Справочники.ВидыЦен.НайтиПоНаименованию("Розничная")
    Запрос.УстановитьПараметр("ВидЦены",
        Справочники.ВидыЦен.НайтиПоНаименованию("Розничная"));
    Запрос.УстановитьПараметр("ВидСебестоимости",
        Справочники.ВидыЦен.НайтиПоНаименованию("Закупочная"));

    Выборка = Запрос.Выполнить().Выбрать();

    // Формируем массив товаров (пакетами по 500)
    МассивТоваров = Новый Массив;
    Счетчик = 0;
    ВсегоОтправлено = 0;

    Пока Выборка.Следующий() Цикл

        Товар = Новый Структура;
        Товар.Вставить("sku", СокрЛП(Выборка.Код));
        Товар.Вставить("name", СокрЛП(Выборка.Наименование));
        Товар.Вставить("category", СокрЛП(Выборка.Категория));
        Товар.Вставить("price", Выборка.Цена);
        Товар.Вставить("cost_price", Выборка.Себестоимость);
        Товар.Вставить("current_stock", Выборка.Остаток);
        Товар.Вставить("unit", СокрЛП(Выборка.ЕдиницаИзмерения));
        Товар.Вставить("barcode", СокрЛП(Выборка.Штрихкод));
        Товар.Вставить("supplier", СокрЛП(Выборка.Поставщик));

        МассивТоваров.Добавить(Товар);
        Счетчик = Счетчик + 1;

        // Отправляем пакетами по 500
        Если Счетчик >= 500 Тогда
            ОтправитьПакетТоваров(МассивТоваров);
            ВсегоОтправлено = ВсегоОтправлено + МассивТоваров.Количество();
            МассивТоваров = Новый Массив;
            Счетчик = 0;
        КонецЕсли;

    КонецЦикла;

    // Отправить оставшиеся
    Если МассивТоваров.Количество() > 0 Тогда
        ОтправитьПакетТоваров(МассивТоваров);
        ВсегоОтправлено = ВсегоОтправлено + МассивТоваров.Количество();
    КонецЕсли;

    ЗаписьЖурналаРегистрации("SBonus.Синхронизация", УровеньЖурналаРегистрации.Информация, , ,
        "Синхронизация завершена. Отправлено товаров: " + ВсегоОтправлено);

КонецПроцедуры

// Отправить пакет товаров в API
Процедура ОтправитьПакетТоваров(МассивТоваров)

    Данные = Новый Структура;
    Данные.Вставить("products", МассивТоваров);

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    JSONСтрока = ЗаписьJSON.Закрыть();

    Результат = ОтправитьЗапрос("/api/v1/webhook/1c/products-sync", JSONСтрока);

    Если НЕ Результат.Успех Тогда
        ЗаписьЖурналаРегистрации("SBonus.Ошибка", УровеньЖурналаРегистрации.Ошибка, , ,
            "Ошибка синхронизации товаров: " + Результат.Тело);
    КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбновлениеОстатков

// Обновление остатков товаров в SBonus+
// Вызывается регламентным заданием каждый час
//
Процедура ОбновлениеОстатковВSBonus() Экспорт

    Если НЕ ИнтеграцияВключена() Тогда
        Возврат;
    КонецЕсли;

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    Номенклатура.Код КАК Код,
    |    ЕСТЬNULL(ОстаткиТоваров.КоличествоОстаток, 0) КАК Остаток
    |ИЗ
    |    Справочник.Номенклатура КАК Номенклатура
    |
    |    ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки КАК ОстаткиТоваров
    |    ПО Номенклатура.Ссылка = ОстаткиТоваров.Номенклатура
    |
    |ГДЕ
    |    Номенклатура.ЭтоГруппа = ЛОЖЬ
    |    И НЕ Номенклатура.ПометкаУдаления";

    Выборка = Запрос.Выполнить().Выбрать();

    МассивОстатков = Новый Массив;
    Счетчик = 0;

    Пока Выборка.Следующий() Цикл

        Элемент = Новый Структура;
        Элемент.Вставить("sku", СокрЛП(Выборка.Код));
        Элемент.Вставить("current_stock", Выборка.Остаток);

        МассивОстатков.Добавить(Элемент);
        Счетчик = Счетчик + 1;

        Если Счетчик >= 1000 Тогда
            ОтправитьПакетОстатков(МассивОстатков);
            МассивОстатков = Новый Массив;
            Счетчик = 0;
        КонецЕсли;

    КонецЦикла;

    Если МассивОстатков.Количество() > 0 Тогда
        ОтправитьПакетОстатков(МассивОстатков);
    КонецЕсли;

КонецПроцедуры

Процедура ОтправитьПакетОстатков(МассивОстатков)

    Данные = Новый Структура;
    Данные.Вставить("items", МассивОстатков);

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    JSONСтрока = ЗаписьJSON.Закрыть();

    Результат = ОтправитьЗапрос("/api/v1/webhook/1c/stock-update", JSONСтрока);

    Если НЕ Результат.Успех Тогда
        ЗаписьЖурналаРегистрации("SBonus.Ошибка", УровеньЖурналаРегистрации.Ошибка, , ,
            "Ошибка обновления остатков: " + Результат.Тело);
    КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработкаЧека

// Обработчик проведения чека ККМ — отправка данных о покупке в SBonus+
// Подписка на событие: ДокументОбъект.ЧекККМ.ОбработкаПроведения
//
// Параметры:
//   Источник - ДокументОбъект.ЧекККМ - проводимый документ
//   Отказ    - Булево
//   РежимПроведения - РежимПроведенияДокумента
//
Процедура ПриПроведенииЧекаSBonus(Источник, Отказ, РежимПроведения) Экспорт

    Если Отказ Тогда
        Возврат;
    КонецЕсли;

    Если НЕ ИнтеграцияВключена() Тогда
        Возврат;
    КонецЕсли;

    // Только продажи (не возвраты)
    Если Источник.ВидОперации <> Перечисления.ВидыОперацийЧекККМ.Продажа Тогда
        Возврат;
    КонецЕсли;

    Попытка
        ОтправитьДанныеЧека(Источник);
    Исключение
        // Не блокируем проведение чека при ошибке отправки
        ЗаписьЖурналаРегистрации("SBonus.Ошибка", УровеньЖурналаРегистрации.Ошибка, , ,
            "Ошибка отправки чека в SBonus+: " + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры

// Собрать данные чека и отправить в API
Процедура ОтправитьДанныеЧека(Чек)

    // ── Определить телефон клиента ──
    ТелефонКлиента = "";

    // Вариант 1: Если в чеке есть реквизит "Контрагент" или "Покупатель"
    Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент", Чек.Метаданные()) Тогда
        Если ЗначениеЗаполнено(Чек.Контрагент) Тогда
            ТелефонКлиента = ПолучитьТелефонКонтрагента(Чек.Контрагент);
        КонецЕсли;
    КонецЕсли;

    // Вариант 2: Если есть дисконтная карта
    Если ПустаяСтрока(ТелефонКлиента) Тогда
        Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ДисконтнаяКарта", Чек.Метаданные()) Тогда
            Если ЗначениеЗаполнено(Чек.ДисконтнаяКарта) Тогда
                ТелефонКлиента = ПолучитьТелефонПоДисконтнойКарте(Чек.ДисконтнаяКарта);
            КонецЕсли;
        КонецЕсли;
    КонецЕсли;

    // Если нет телефона — не отправляем (бонус не начислится)
    Если ПустаяСтрока(ТелефонКлиента) Тогда
        Возврат;
    КонецЕсли;

    // ── Собрать позиции чека ──
    МассивПозиций = Новый Массив;
    СуммаЧека = 0;

    Для Каждого Строка Из Чек.Товары Цикл

        Позиция = Новый Структура;
        Позиция.Вставить("sku", СокрЛП(Строка.Номенклатура.Код));
        Позиция.Вставить("name", СокрЛП(Строка.Номенклатура.Наименование));
        Позиция.Вставить("quantity", Строка.Количество);
        Позиция.Вставить("price", Строка.Цена);
        Позиция.Вставить("total", Строка.Сумма);

        МассивПозиций.Добавить(Позиция);
        СуммаЧека = СуммаЧека + Строка.Сумма;

    КонецЦикла;

    // ── Формируем JSON ──
    Данные = Новый Структура;
    Данные.Вставить("customer_phone", ТелефонКлиента);
    Данные.Вставить("purchase_amount", СуммаЧека);
    Данные.Вставить("receipt_number", СокрЛП(Чек.Номер));
    Данные.Вставить("items", МассивПозиций);

    // Branch ID — если несколько филиалов, укажите UUID из SBonus+
    // Данные.Вставить("branch_id", "ваш-branch-uuid");

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    JSONСтрока = ЗаписьJSON.Закрыть();

    // ── Отправить в SBonus+ API ──
    Результат = ОтправитьЗапрос("/api/v1/webhook/1c/purchase", JSONСтрока);

    Если Результат.Успех Тогда
        ЗаписьЖурналаРегистрации("SBonus.Чек", УровеньЖурналаРегистрации.Информация, , ,
            "Чек " + Чек.Номер + " отправлен в SBonus+. Сумма: " + СуммаЧека + ", Клиент: " + ТелефонКлиента);
    Иначе
        ЗаписьЖурналаРегистрации("SBonus.Ошибка", УровеньЖурналаРегистрации.Предупреждение, , ,
            "Чек " + Чек.Номер + " — ошибка: " + Результат.КодОтвета + " " + Результат.Тело);
    КонецЕсли;

КонецПроцедуры

// Получить телефон контрагента
Функция ПолучитьТелефонКонтрагента(Контрагент)

    Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
        Возврат "";
    КонецЕсли;

    // Из контактной информации
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |    КонтактнаяИнформация.Представление КАК Телефон
    |ИЗ
    |    Справочник.Контрагенты.КонтактнаяИнформация КАК КонтактнаяИнформация
    |ГДЕ
    |    КонтактнаяИнформация.Ссылка = &Контрагент
    |    И КонтактнаяИнформация.Тип = &ТипТелефон";

    Запрос.УстановитьПараметр("Контрагент", Контрагент);
    Запрос.УстановитьПараметр("ТипТелефон",
        Перечисления.ТипыКонтактнойИнформации.Телефон);

    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат НормализоватьТелефон(Выборка.Телефон);
    КонецЕсли;

    Возврат "";

КонецФункции

// Получить телефон по дисконтной карте
Функция ПолучитьТелефонПоДисконтнойКарте(ДисконтнаяКарта)

    Если НЕ ЗначениеЗаполнено(ДисконтнаяКарта) Тогда
        Возврат "";
    КонецЕсли;

    // Если у дисконтной карты есть владелец-контрагент
    Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Владелец", ДисконтнаяКарта.Метаданные()) Тогда
        Если ЗначениеЗаполнено(ДисконтнаяКарта.Владелец) Тогда
            Возврат ПолучитьТелефонКонтрагента(ДисконтнаяКарта.Владелец);
        КонецЕсли;
    КонецЕсли;

    Возврат "";

КонецФункции

// Нормализовать телефон в формат +996XXXXXXXXX
Функция НормализоватьТелефон(Телефон)

    // Оставить только цифры
    ТолькоЦифры = "";
    Для Позиция = 1 По СтрДлина(Телефон) Цикл
        Символ = Сред(Телефон, Позиция, 1);
        Если Символ >= "0" И Символ <= "9" Тогда
            ТолькоЦифры = ТолькоЦифры + Символ;
        КонецЕсли;
    КонецЦикла;

    // Привести к формату +996XXXXXXXXX
    Если СтрНачинаетсяС(ТолькоЦифры, "996") И СтрДлина(ТолькоЦифры) = 12 Тогда
        Возврат "+" + ТолькоЦифры;
    ИначеЕсли СтрНачинаетсяС(ТолькоЦифры, "0") И СтрДлина(ТолькоЦифры) = 10 Тогда
        Возврат "+996" + Сред(ТолькоЦифры, 2);
    ИначеЕсли СтрДлина(ТолькоЦифры) = 9 Тогда
        Возврат "+996" + ТолькоЦифры;
    КонецЕсли;

    Возврат "+" + ТолькоЦифры;

КонецФункции

#КонецОбласти

#Область Тестирование

// Тест соединения с SBonus+ API
Процедура ТестСоединения() Экспорт

    APIUrl = ПолучитьURLAPI();
    Секрет = ПолучитьСекрет();

    Если ПустаяСтрока(APIUrl) Тогда
        Сообщить("ОШИБКА: Константа SB_APIUrl не заполнена!");
        Возврат;
    КонецЕсли;

    Если ПустаяСтрока(Секрет) Тогда
        Сообщить("ОШИБКА: Константа SB_WebhookSecret не заполнена!");
        Возврат;
    КонецЕсли;

    Сообщить("API URL: " + APIUrl);
    Сообщить("Секрет: настроен (" + СтрДлина(Секрет) + " символов)");

    // Попробовать подключиться
    Попытка
        СтруктураURL = РазобратьURL(APIUrl);
        Порт = ?(СтруктураURL.Схема = "https", 443, 80);

        Соединение = Новый HTTPСоединение(
            СтруктураURL.Хост, Порт, , , , ,
            Новый ЗащищенноеСоединениеOpenSSL()
        );

        Запрос = Новый HTTPЗапрос("/health");
        Ответ = Соединение.ВызватьHTTPМетод("GET", Запрос);

        Сообщить("Код ответа: " + Ответ.КодСостояния);
        Сообщить("Тело: " + Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8));

        Если Ответ.КодСостояния = 200 Тогда
            Сообщить("✅ Соединение с SBonus+ API успешно!");
        Иначе
            Сообщить("⚠️ API доступен, но вернул код " + Ответ.КодСостояния);
        КонецЕсли;

    Исключение
        Сообщить("❌ ОШИБКА подключения: " + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры

// Тестовая отправка одного товара
Процедура ТестОтправкиТовара() Экспорт

    Товар = Новый Структура;
    Товар.Вставить("sku", "TEST-001");
    Товар.Вставить("name", "Тестовый товар SBonus+");
    Товар.Вставить("category", "Тест");
    Товар.Вставить("price", 1000);
    Товар.Вставить("cost_price", 800);
    Товар.Вставить("current_stock", 10);
    Товар.Вставить("unit", "шт");

    Данные = Новый Структура;
    Данные.Вставить("products", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Товар));

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    JSONСтрока = ЗаписьJSON.Закрыть();

    Результат = ОтправитьЗапрос("/api/v1/webhook/1c/products-sync", JSONСтрока);

    Сообщить("Код: " + Результат.КодОтвета);
    Сообщить("Ответ: " + Результат.Тело);

    Если Результат.Успех Тогда
        Сообщить("✅ Тестовый товар успешно отправлен!");
    Иначе
        Сообщить("❌ Ошибка: " + Результат.Тело);
    КонецЕсли;

КонецПроцедуры

#КонецОбласти
