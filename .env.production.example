# ═══════════════════════════════════════════════════════════
# S BONUS — PRODUCTION ENVIRONMENT (VPS deploy)
# Скопируйте этот файл в .env.production и заполните значения
# ═══════════════════════════════════════════════════════════

# ─── Магазин ───
SHOP_NAME=Смарт Центр
SHOP_BONUS_NAME=S Bonus
SHOP_ADDRESS=Ошская обл., Аравандский р-н, ул. Ош-3000, 86
SHOP_PHONE=+996557100505
SHOP_COUNTRY=Кыргызстан
SHOP_CURRENCY=KGS
SHOP_TIMEZONE=Asia/Bishkek

# ─── Бонусная логика ───
MIN_PURCHASE_FOR_BONUS=500
MAX_SPEND_PERCENT=30
BIRTHDAY_BONUS=200
REFERRAL_BONUS_INVITER=100
REFERRAL_BONUS_INVITEE=50

# ─── PostgreSQL (ОБЯЗАТЕЛЬНО СМЕНИТЕ ПАРОЛЬ!) ───
POSTGRES_USER=sbonus
POSTGRES_PASSWORD=__CHANGE_ME_strong_password_min_32_chars__
POSTGRES_DB=sbonus_db
# DATABASE_URL формируется автоматически в docker-compose.prod.yml

# ─── Redis ───
# REDIS_URL формируется автоматически в docker-compose.prod.yml

# ─── JWT ───
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Rate Limiting ───
LOGIN_RATE_LIMIT=5/15min
API_RATE_LIMIT=100/min

# ─── 1С Интеграция (ОБЯЗАТЕЛЬНО СМЕНИТЕ SECRET!) ───
ENABLE_1C_WEBHOOK=false
WEBHOOK_1C_SECRET=__CHANGE_ME_random_64_chars__
WEBHOOK_1C_ALLOWED_IPS=127.0.0.1

# ─── Green API (WhatsApp) — заполнить после подключения ───
GREENAPI_INSTANCE_ID=
GREENAPI_API_TOKEN=
ENABLE_WHATSAPP_NOTIFICATIONS=false

# ─── Личный кабинет клиента ───
CUSTOMER_CABINET_BASE_URL=https://cabinet.smartcentr.store
CUSTOMER_TOKEN_EXPIRE_DAYS=30
CUSTOMER_MAGIC_LINK_EXPIRE_MINUTES=15

# ─── CORS (production domains) ───
CORS_ORIGINS=https://admin.smartcentr.store,https://cabinet.smartcentr.store

# ─── Приложение ───
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ─── Build-time API URL для Next.js (admin и client) ───
# Эти переменные читает docker-compose при build'е фронтендов
ADMIN_API_URL=https://api.smartcentr.store
CLIENT_API_URL=https://api.smartcentr.store
