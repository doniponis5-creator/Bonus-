# ─── 1. Build stage: Expo web export ──────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install --no-audit --no-fund --legacy-peer-deps

COPY . .

ARG EXPO_PUBLIC_API_URL=https://api.smartcentr.store
ENV EXPO_PUBLIC_API_URL=$EXPO_PUBLIC_API_URL

# Expo web static export → dist/
RUN npx expo export --platform web --output-dir dist

# ─── 2. Runtime: Nginx serve static ───────────────────
FROM nginx:1.27-alpine AS runner

# SPA-mode config: hamma route'ni index.html'ga yo'naltirish
RUN echo 'server {                                            \n\
    listen 3000;                                              \n\
    root /usr/share/nginx/html;                               \n\
    index index.html;                                         \n\
    gzip on;                                                  \n\
    gzip_types text/css application/javascript application/json image/svg+xml; \n\
    location / {                                              \n\
        try_files $uri $uri/ /index.html;                     \n\
    }                                                         \n\
    location ~* \.(?:js|css|png|svg|ico|woff2?)$ {            \n\
        expires 30d;                                          \n\
        access_log off;                                       \n\
    }                                                         \n\
}' > /etc/nginx/conf.d/default.conf

COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
