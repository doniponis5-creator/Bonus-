# ─── 1. Build stage: Expo web export ──────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install --no-audit --no-fund --legacy-peer-deps

COPY . .

ARG EXPO_PUBLIC_API_URL=https://api.smartcentr.store
ENV EXPO_PUBLIC_API_URL=$EXPO_PUBLIC_API_URL

# Expo web static export → dist/
RUN npx expo export --platform web --output-dir dist

# Expo SDK 54 bundle uses import.meta — inject type="module" into script tags
RUN sed -i 's|<script src=|<script type="module" src=|g' dist/index.html

# ─── 2. Runtime: Nginx serve static ───────────────────
FROM nginx:1.27-alpine AS runner

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
